generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  createdAt     DateTime       @default(now())
  savedColleges SavedCollege[]
  activities    UserActivity[]
}

model College {
  id                     String         @id @default(cuid())
  name                   String
  location               String
  state                  String
  type                   String
  fees                   Int
  rating                 Float
  entranceExam           String
  cutoffRank             Int
  placementAvgSalary     Int
  placementHighestSalary Int
  established            Int
  courses                String[]
  savedBy                SavedCollege[]
}

model SavedCollege {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  savedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  college   College  @relation(fields: [collegeId], references: [id])

  @@unique([userId, collegeId])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}